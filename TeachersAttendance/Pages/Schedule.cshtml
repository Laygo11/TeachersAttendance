@page
@model TeachersAttendance.Pages.ScheduleModel
@{
    ViewData["Title"] = "My Schedule";
    Layout = "_Layout";
}

<style>
    .schedule-wrapper {
        max-width: 600px;
        margin: 2rem auto;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .teacher-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #212529;
    }

    .teacher-dept {
        font-size: 0.825rem;
        color: #6c757d;
        margin-top: 0.1rem;
    }

    .logout-btn {
        font-size: 0.85rem;
        color: #dc3545;
        text-decoration: none;
        border: 1px solid #f5c2c7;
        padding: 0.35rem 0.85rem;
        border-radius: 6px;
        background: #fff5f5;
    }

        .logout-btn:hover {
            background: #f8d7da;
            color: #b02a37;
        }

    .date-row {
        font-size: 0.875rem;
        color: #6c757d;
        margin-bottom: 1.25rem;
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #adb5bd;
        margin-bottom: 0.75rem;
    }

    .schedule-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-left: 4px solid #0d6efd;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
    }

        .schedule-card .subject {
            font-weight: 600;
            font-size: 1rem;
            color: #212529;
            margin-bottom: 0.3rem;
        }

        .schedule-card .meta {
            font-size: 0.85rem;
            color: #6c757d;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

    .no-schedule {
        text-align: center;
        padding: 2.5rem 1rem;
        color: #6c757d;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px dashed #dee2e6;
        font-size: 0.9rem;
    }

    .attendance-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #d1e7dd;
        color: #0a3622;
        border-radius: 20px;
        padding: 0.3rem 0.85rem;
        font-size: 0.78rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
    }

    .full-schedule-link {
        display: block;
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.875rem;
        color: #0d6efd;
        cursor: pointer;
        text-decoration: none;
    }

        .full-schedule-link:hover {
            text-decoration: underline;
        }

    /* Full weekly schedule */
    .weekly-section {
        margin-top: 2rem;
    }

    .day-group {
        margin-bottom: 1.25rem;
    }

    .day-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #868e96;
        margin-bottom: 0.5rem;
    }

    .schedule-card.weekly {
        border-left-color: #6c757d;
        padding: 0.75rem 1rem;
    }

        .schedule-card.weekly .subject {
            font-size: 0.95rem;
        }

        .schedule-card.weekly .meta {
            font-size: 0.82rem;
        }
</style>

<div class="schedule-wrapper">
    <!-- Top bar -->
    <div class="top-bar">
        <div>
            <div class="teacher-name">@Model.TeacherName</div>
            <div class="teacher-dept">@Model.Department</div>
        </div>
        <a href="/Logout" class="logout-btn">Sign out</a>
    </div>

    <!-- Attendance badge -->
    <div class="attendance-badge">✅ Attendance logged for today</div>

    <!-- Today's schedule -->
    <div class="date-row">📅 @DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
    <div class="section-title">Today's Classes</div>

    @if (Model.TodaySchedule.Count == 0)
    {
        <div class="no-schedule">No classes scheduled for today.</div>
    }
    else
    {
        @foreach (var item in Model.TodaySchedule)
        {
            <div class="schedule-card">
                <div class="subject">@item.SubjectName</div>
                <div class="meta">
                    <span>🕐 @item.StartTime – @item.EndTime</span>
                    <span>📍 @item.Room</span>
                </div>
            </div>
        }
    }

    <!-- Weekly schedule toggle -->
    <a class="full-schedule-link" onclick="toggleWeekly()" id="weeklyToggle">▼ View full weekly schedule</a>

    <div class="weekly-section" id="weeklySection" style="display:none;">
        <div class="section-title" style="margin-top:0.5rem;">Weekly Schedule</div>
        @foreach (var day in Model.WeeklySchedule.Keys)
        {
            <div class="day-group">
                <div class="day-label">@day</div>
                @foreach (var item in Model.WeeklySchedule[day])
                {
                    <div class="schedule-card weekly">
                        <div class="subject">@item.SubjectName</div>
                        <div class="meta">
                            <span>🕐 @item.StartTime – @item.EndTime</span>
                            <span>📍 @item.Room</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function toggleWeekly() {
        const section = document.getElementById('weeklySection');
        const toggle = document.getElementById('weeklyToggle');
        if (section.style.display === 'none') {
            section.style.display = 'block';
            toggle.textContent = '▲ Hide weekly schedule';
        } else {
            section.style.display = 'none';
            toggle.textContent = '▼ View full weekly schedule';
        }
    }
</script>